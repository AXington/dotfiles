#!/usr/bin/env bash
set -euo pipefail

# Install Oh My Zsh non-interactively (no shell switch, no auto-launch)
RUNZSH=no CHSH=no sh -c \
    "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

# Install zsh-syntax-highlighting plugin
git clone --depth=1 \
    https://github.com/zsh-users/zsh-syntax-highlighting.git \
    "${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting"

# Add plugin to .zshrc plugins list
if grep -q "^plugins=(" "$HOME/.zshrc"; then
    # Insert zsh-syntax-highlighting into the plugins=(...) block
    awk '/^plugins=\(/{
        if ($0 !~ /zsh-syntax-highlighting/) {
            sub(/\)$/, " zsh-syntax-highlighting)")
        }
    }1' "$HOME/.zshrc" > "$HOME/.zshrc_tmp"
    mv "$HOME/.zshrc" "$HOME/.zshrc.bak"
    mv "$HOME/.zshrc_tmp" "$HOME/.zshrc"
fi

# Set default shell to zsh
ZSH_PATH="$(command -v zsh)"
grep -qxF "$ZSH_PATH" /etc/shells || echo "$ZSH_PATH" | sudo tee -a /etc/shells
sudo chsh -s "$ZSH_PATH" "$USER"

echo "Oh My Zsh installed. Start a new shell session to apply."
